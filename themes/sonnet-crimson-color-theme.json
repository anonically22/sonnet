{
	"name": "Sonnet Crimson",
	"type": "dark",
	"colors": {
		"editor.background": "#000000",
		"editor.foreground": "#f5f5f5",
		"editor.lineHighlightBackground": "#1c1c1c",
		"editor.selectionBackground": "#2a1014",
		"editor.selectionHighlightBackground": "#2a101466",
		"editor.findMatchBackground": "#a30f2955",
		"editor.findMatchHighlightBackground": "#a30f2933",
		"editorCursor.foreground": "#e8112e",
		"editorLineNumber.foreground": "#5c5c5c",
		"editorLineNumber.activeForeground": "#a30f29",
		"editorIndentGuide.background1": "#2a2a2a",
		"editorIndentGuide.activeBackground1": "#5c0a18",
		"editorWhitespace.foreground": "#2a2a2a",
		"sideBar.background": "#121212",
		"sideBar.foreground": "#9a9a9a",
		"sideBarTitle.foreground": "#f5f5f5",
		"activityBar.background": "#121212",
		"activityBar.foreground": "#f5f5f5",
		"activityBar.inactiveForeground": "#5c5c5c",
		"activityBarBadge.background": "#a30f29",
		"activityBarBadge.foreground": "#000000",
		"editorGroupHeader.tabsBackground": "#121212",
		"tab.activeBackground": "#000000",
		"tab.inactiveBackground": "#121212",
		"tab.activeForeground": "#f5f5f5",
		"tab.inactiveForeground": "#9a9a9a",
		"tab.activeBorderTop": "#a30f29",
		"tab.border": "#2a2a2a",
		"statusBar.background": "#5c0a18",
		"statusBar.foreground": "#f5f5f5",
		"statusBar.noFolderBackground": "#121212",
		"statusBar.debuggingBackground": "#e8112e",
		"statusBarItem.remoteBackground": "#a30f29",
		"titleBar.activeBackground": "#121212",
		"titleBar.activeForeground": "#f5f5f5",
		"titleBar.inactiveBackground": "#000000",
		"button.background": "#a30f29",
		"button.foreground": "#ffffff",
		"button.hoverBackground": "#e8112e",
		"input.background": "#1c1c1c",
		"input.border": "#2a2a2a",
		"focusBorder": "#a30f29",
		"list.activeSelectionBackground": "#2a1014",
		"list.activeSelectionForeground": "#f5f5f5",
		"list.hoverBackground": "#1c1c1c",
		"list.highlightForeground": "#a30f29",
		"scrollbarSlider.background": "#5c0a1855",
		"scrollbarSlider.hoverBackground": "#5c0a1888",
		"scrollbarSlider.activeBackground": "#a30f29",
		"badge.background": "#a30f29",
		"badge.foreground": "#ffffff",
		"diffEditor.insertedTextBackground": "#5fb87a22",
		"diffEditor.removedTextBackground": "#e8112e22",
		"gitDecoration.modifiedResourceForeground": "#d4d4d4",
		"gitDecoration.deletedResourceForeground": "#e8112e",
		"gitDecoration.untrackedResourceForeground": "#5fb87a",
		"terminal.background": "#000000",
		"terminal.foreground": "#f5f5f5",
		"terminal.ansiRed": "#e8112e",
		"terminal.ansiGreen": "#5fb87a",
		"terminal.ansiYellow": "#d9a441",
		"terminal.ansiBlue": "#8a8a8a",
		"terminal.ansiMagenta": "#a30f29",
		"terminal.ansiCyan": "#d4d4d4"
	},
	"tokenColors": [
		{
			"name": "Comment",
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"fontStyle": "italic",
				"foreground": "#6b6b6b"
			}
		},
		{
			"name": "Keyword",
			"scope": [
				"keyword",
				"keyword.control",
				"keyword.operator.new"
			],
			"settings": {
				"fontStyle": "",
				"foreground": "#a30f29"
			}
		},
		{
			"name": "Storage Type / Modifier / Class Name",
			"scope": [
				"storage.type",
				"storage.modifier",
				"entity.name.type.class"
			],
			"settings": {
				"fontStyle": "",
				"foreground": "#e8112e"
			}
		},
		{
			"name": "Function / Method",
			"scope": [
				"entity.name.function",
				"support.function",
				"meta.function-call"
			],
			"settings": {
				"fontStyle": "",
				"foreground": "#d4d4d4"
			}
		},
		{
			"name": "Variable / Parameter",
			"scope": [
				"variable",
				"variable.parameter",
				"variable.other.readwrite"
			],
			"settings": {
				"fontStyle": "",
				"foreground": "#8a8a8a"
			}
		},
		{
			"name": "Constant / Enum Member",
			"scope": [
				"variable.other.constant",
				"variable.other.enummember"
			],
			"settings": {
				"fontStyle": "",
				"foreground": "#a30f29"
			}
		},
		{
			"name": "String",
			"scope": [
				"string",
				"string.quoted"
			],
			"settings": {
				"fontStyle": "",
				"foreground": "#9a9a9a"
			}
		},
		{
			"name": "Numeric Constant",
			"scope": [
				"constant.numeric"
			],
			"settings": {
				"fontStyle": "",
				"foreground": "#e8112e"
			}
		},
		{
			"name": "Language Constant (true/false/null)",
			"scope": [
				"constant.language"
			],
			"settings": {
				"fontStyle": "bold",
				"foreground": "#a30f29"
			}
		},
		{
			"name": "HTML / JSX Tag",
			"scope": [
				"entity.name.tag"
			],
			"settings": {
				"fontStyle": "",
				"foreground": "#a30f29"
			}
		},
		{
			"name": "Attribute Name",
			"scope": [
				"entity.other.attribute-name"
			],
			"settings": {
				"fontStyle": "",
				"foreground": "#d4d4d4"
			}
		},
		{
			"name": "Punctuation",
			"scope": [
				"punctuation",
				"punctuation.separator",
				"punctuation.terminator"
			],
			"settings": {
				"fontStyle": "",
				"foreground": "#9a9a9a"
			}
		},
		{
			"name": "Support Class / Namespace",
			"scope": [
				"support.class",
				"entity.name.namespace"
			],
			"settings": {
				"fontStyle": "",
				"foreground": "#e8112e"
			}
		},
		{
			"name": "Markup Bold",
			"scope": [
				"markup.bold"
			],
			"settings": {
				"fontStyle": "bold",
				"foreground": "#f5f5f5"
			}
		},
		{
			"name": "Markup Italic",
			"scope": [
				"markup.italic"
			],
			"settings": {
				"fontStyle": "italic",
				"foreground": "#f5f5f5"
			}
		},
		{
			"name": "Markup Heading",
			"scope": [
				"markup.heading"
			],
			"settings": {
				"fontStyle": "bold",
				"foreground": "#e8112e"
			}
		},
		{
			"name": "Invalid",
			"scope": [
				"invalid",
				"invalid.illegal"
			],
			"settings": {
				"fontStyle": "bold",
				"foreground": "#ffffff",
				"background": "#e8112e"
			}
		}
	]
}
